rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to settings
    match /settings/{document} {
      allow read, write: if true;
    }
    
    // Allow read/write access to products
    match /products/{document} {
      allow read, write: if true;
    }

    // Allow read/write access to reviews under products
    match /products/{productId}/reviews/{document} {
      allow read, write: if true;
    }
    
    // Allow read/write access to orders
    match /orders/{document} {
      allow read, write: if true;
    }
    
    // Allow read/write access to webhook_logs
    match /webhook_logs/{document} {
      allow read, write: if true;
    }
  }
}
